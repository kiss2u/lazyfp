{
  "invoice_no": {
    "primary": [
      {"pattern": "发\\s*票\\s*号\\s*码[:：]\\s*(\\d+)", "flags": 0, "desc": "Standard invoice number"},
      {"pattern": "发票号码[:：]?\\s*(\\d{20}|\\d{8,12})", "flags": 0, "desc": "Full-electric 20-digit or traditional 8-12 digit"}
    ],
    "fallback": [
      {"pattern": "\\b\\d{20}\\b", "flags": 0, "desc": "Pure 20-digit number (full-electric)"},
      {"pattern": "客户账号\\s*(\\d+)", "flags": 0, "desc": "China Mobile customer account"},
      {"pattern": "监\\s*(\\d{8})\\b", "flags": 0, "desc": "Old unified invoice monitor number"},
      {"pattern": "数电.*?号码[:：]?\\s*(\\d{20})", "flags": 0, "desc": "Digital-electric invoice remark number"}
    ]
  },
  "date": {
    "primary": [
      {"pattern": "开\\s*票\\s*日\\s*期[:：]\\s*(\\d{4}年\\d{1,2}月\\d{1,2}日)", "flags": 0, "desc": "Invoice date (Chinese)"},
      {"pattern": "开\\s*票\\s*日\\s*期[:：]\\s*(\\d{4}[-/]\\d{1,2}[-/]\\d{1,2})", "flags": 0, "desc": "Invoice date (ISO)"},
      {"pattern": "打印日期\\s*(\\d{4}[-/]\\d{1,2}[-/]\\d{1,2})", "flags": 0, "desc": "China Mobile print date"}
    ],
    "fallback": [
      {"pattern": "(\\d{4}年\\d{1,2}月\\d{1,2}日)", "flags": 0, "desc": "Generic Chinese date"},
      {"pattern": "(\\d{4}-\\d{2}-\\d{2})", "flags": 0, "desc": "ISO date YYYY-MM-DD"},
      {"pattern": "(\\d{4})[/\\.](\\d{1,2})[/\\.](\\d{1,2})", "flags": 0, "desc": "YYYY/MM/DD or YYYY.MM.DD"}
    ]
  },
  "amount": {
    "primary": [
      {"pattern": "小写[:：]?\\s*[¥￥]?\\s*([\\d,]+\\.\\d{2})", "flags": 0, "desc": "Lowercase amount with decimals"},
      {"pattern": "价\\s*税\\s*合\\s*计.*?[¥￥]?\\s*([\\d,]+\\.\\d{2})", "flags": 0, "desc": "Price-tax total"},
      {"pattern": "本期总费用\\s*[¥￥]?\\s*([\\d,]+\\.?\\d*)", "flags": 0, "desc": "China Mobile total fee"}
    ],
    "fallback": [
      {"pattern": "(小写|价税合计)\\D{0,50}([¥￥]?\\d+\\.?\\d{2})", "flags": 0, "desc": "Flattened lowercase/total amount"},
      {"pattern": "[壹贰叁肆伍陆柒捌玖拾佰仟万亿圆角分整]{2,}\\D{0,10}([¥￥]?\\d+\\.?\\d{2})", "flags": 0, "desc": "Chinese uppercase amount heuristic"}
    ]
  },
  "purchaser": {
    "primary": [
      {"pattern": "(?:购)?名称[:：](.+?)(?:销|售|卖|纳税|统一|地址|开户)", "flags": 0, "desc": "Purchaser name label"},
      {"pattern": "买名称\\s*[:：]?\\s*([\\u4e00-\\u9fa5()（）]{2,50}?)(?:售名称|方方|方信)", "flags": 0, "desc": "JD-style: 买名称 without colon"},
      {"pattern": "客户\\s+([\\u4e00-\\u9fa5()（）]{2,50})\\s+集团", "flags": 0, "desc": "China Mobile purchaser (between 客户 and 集团)"}
    ],
    "fallback": [
      {"pattern": "名\\s*称\\s*[:：]\\s*([^\\s]+)", "flags": 0, "desc": "Generic name label"},
      {"pattern": "购买方名称[:：]\\s*([^\\n:：]{2,50})", "flags": 0, "desc": "Digital-electric purchaser full label"},
      {"pattern": "([^\\n:：]{4,30}?)\\s*统一(?:信用代码|社会信用代码)[:：]\\s*[A-Z0-9]{18}", "flags": 0, "desc": "Company name via credit code", "group": 1}
    ]
  },
  "seller": {
    "primary": [
      {"pattern": "(?:销|售)名称[:：](.+?)(?:买售|纳税|统一|地址|开户|复核|开票)", "flags": 0, "desc": "Seller name label"},
      {"pattern": "售名称\\s*[:：]?\\s*([\\u4e00-\\u9fa5()（）]{2,50}?)\\s*[:：]{0,2}方", "flags": 0, "desc": "JD-style: 售名称 followed by company"},
      {"pattern": "(中国移动通信集团[\\u4e00-\\u9fa5]+有限公司)", "flags": 0, "desc": "China Mobile seller"}
    ],
    "fallback": [
      {"pattern": "销售方名称[:：]\\s*([^\\n:：]{2,50})", "flags": 0, "desc": "Digital-electric seller full label"}
    ]
  }
}
